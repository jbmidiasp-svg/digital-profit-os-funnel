# Digital Profit OS - Render Free preflight environment
# Do not commit real secrets. Paste production values in Render only.

DEPLOY_PLATFORM=render
FREE_DEPLOY_CONFIRMED=true
FUNNEL_ENV=production
FUNNEL_TEST_MODE=false
REAL_SALES_APPROVED=false
ADS_APPROVED=false
PORT=4321

PUBLIC_BASE_URL=https://your-service-name.onrender.com

# Generate fresh values and paste them in Render Variables.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DELIVERY_SECRET=replace_with_a_long_random_secret
REPORT_SECRET=replace_with_a_long_random_report_secret

# Render Free filesystem is ephemeral. These paths are for blocked preflight only.
PERSISTENCE_TRUSTED_FOR_REAL_SALES=false
FUNNEL_EVENT_LOG=/tmp/digital-profit-os/event-log.jsonl
FUNNEL_ORDERS=/tmp/digital-profit-os/orders.json
FUNNEL_SPEND_LOG=/tmp/digital-profit-os/spend-log.csv

# Keep Mercado Pago empty until persistence and GO/NO-GO are resolved.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Paid acquisition remains blocked.
ADS_DAILY_BUDGET_BRL=5
ADS_CYCLE_BUDGET_CAP_BRL=25
